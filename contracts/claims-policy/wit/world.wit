/// claims-policy WIT world — ClaimsPilot protected claim decision.
///
/// Policy-only contract: it decides allow / deny / needs-escalation for a
/// claim against the caller's delegated grant. It carries NO claimant PII.
/// The claim decision input is the sanitized policy envelope only
/// (amounts, claim type, region, grant scope, identity/host flags) — never
/// names, documents, or contact details. The PII-bearing insurer call is a
/// separate, later milestone that uses `host:interfaces/http-with-placeholders`
/// so plaintext PII is resolved inside the TEE and never enters WASM memory.
package claimspilot:claims-policy@0.1.0;

world claims-policy {
    export contracts;
}

interface contracts {
    /// Standard 3-field envelope used by Terminal 3 tenant contracts.
    /// `input`        — JSON-serialized request payload (here: ClaimInput).
    /// `user-profile` — None for this policy-only contract (no PII).
    /// `context`      — JSON-serialized node-minted context (unused here).
    record generic-input {
        input:        option<list<u8>>,
        user-profile: option<list<u8>>,
        context:      option<list<u8>>,
    }

    /// Evaluate a claim against the delegated grant.
    /// Input  (JSON): ClaimInput  — sanitized policy envelope, NO PII.
    /// Output (JSON): ClaimDecision { decision, reasons }.
    evaluate-claim: func(req: generic-input) -> result<list<u8>, string>;
}
