/// claims-policy WIT world — ClaimsPilot protected claim decision + submit.
///
/// `evaluate-claim` stays policy-only: it decides allow / deny /
/// needs-escalation for a claim against the caller's delegated grant and
/// carries NO claimant PII. `submit-claim` is the approved-claim outbound path:
/// it templates `{{profile.*}}` markers into an insurer payload and uses
/// `host:interfaces/http-with-placeholders`, so plaintext PII is resolved by
/// the host inside the TEE and never enters WASM memory.
package claimspilot:claims-policy@0.2.0;

world claims-policy {
    import host:interfaces/http-with-placeholders@2.1.0;

    export contracts;
}

interface contracts {
    /// Standard 3-field envelope used by Terminal 3 tenant contracts.
    /// `input`        — JSON-serialized request payload (here: ClaimInput).
    /// `user-profile` — None for this policy-only contract (no PII).
    /// `context`      — JSON-serialized node-minted context (unused here).
    record generic-input {
        input:        option<list<u8>>,
        user-profile: option<list<u8>>,
        context:      option<list<u8>>,
    }

    /// Evaluate a claim against the delegated grant.
    /// Input  (JSON): ClaimInput  — sanitized policy envelope, NO PII.
    /// Output (JSON): ClaimDecision { decision, reasons }.
    evaluate-claim: func(req: generic-input) -> result<list<u8>, string>;

    /// Submit an already-approved claim to the insurer through placeholder
    /// outbound HTTP. Input carries URL, claim metadata, idempotency key, and
    /// allowed placeholder markers only — never resolved profile values.
    /// Output (JSON): SubmitClaimResult { status, claim_id, insurer_reference }.
    submit-claim: func(req: generic-input) -> result<list<u8>, string>;
}
