# Terminal 3 sandbox key from https://www.terminal3.io/products/agent-developer-kit
T3N_API_KEY=

# Optional display-only DID if you want the dashboard to show the claimed DID before live auth succeeds.
NEXT_PUBLIC_T3_DID=
DID=

# Optional live LLM planner for /dashboard/agent.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional app mode toggles.
CLAIMSPILOT_T3_ENVIRONMENT=testnet
CLAIMSPILOT_DEMO_MODE=false
