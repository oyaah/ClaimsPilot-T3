# Terminal 3 sandbox key from https://www.terminal3.io/products/agent-developer-kit
T3N_API_KEY=

# Optional display-only DID if you want the dashboard to show the claimed DID before live auth succeeds.
NEXT_PUBLIC_T3_DID=
DID=

# Optional live LLM planner for /dashboard/agent.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional app mode toggles.
CLAIMSPILOT_T3_ENVIRONMENT=testnet
CLAIMSPILOT_DEMO_MODE=false

# Public base URL for the mock insurer endpoint used by submit-claim.
# Example: https://your-render-service.onrender.com
CLAIMSPILOT_INSURER_BASE_URL=

# Set on Vercel only after Render is deployed, so frontend API calls proxy to Render.
CLAIMSPILOT_BACKEND_URL=

# Public-safe contract registration metadata for hosted backends.
CLAIMSPILOT_CONTRACT_SCRIPT_NAME=
CLAIMSPILOT_CONTRACT_VERSION=0.2.0
CLAIMSPILOT_CONTRACT_TENANT_DID=
CLAIMSPILOT_CONTRACT_TAIL=claims-policy
CLAIMSPILOT_CONTRACT_ID=
CLAIMSPILOT_CONTRACT_REGISTERED_AT=
