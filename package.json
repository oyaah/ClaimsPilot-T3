{
  "name": "claimspilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed.ts",
    "verify": "tsx scripts/verify-setup.ts",
    "t3:build-contract": "cd contracts/claims-policy && cargo build --target wasm32-wasip2 --release",
    "t3:register": "tsx scripts/t3-register-contract.ts",
    "t3:invoke": "tsx scripts/t3-invoke-contract.ts"
  },
  "dependencies": {
    "@terminal3/t3n-sdk": "^3.5.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.17.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.7",
    "jsdom": "^27.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
